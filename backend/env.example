# MongoDB
MONGODB_URI=mongodb://localhost:27017/employee-recommendation-system

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Python AI Service
AI_SERVICE_URL=http://localhost:8000
AI_FEEDBACK_ENABLED=true

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=HR System <noreply@company.com>

# Anthropic (for Python service)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/users/google/callback
FRONTEND_URL=http://localhost:5173

# OpenRouter (prompt rewrite in backend /chat/rewrite)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_MS=20000
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_TITLE=SkillUpTn
# false => use local fallback if OpenRouter is unavailable or not configured
OPENROUTER_STRICT=false

# Twilio SMS — rappel automatique aux employés recommandés
# Obtenez vos credentials sur https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Transport (Uber price estimates for employee commute)
UBER_SERVER_TOKEN=your_uber_server_token
UBER_PRICE_ESTIMATE_URL=https://api.uber.com/v1.2/estimates/price
# Usually "Token" for server token flow, or "Bearer" for OAuth token
UBER_AUTH_SCHEME=Token
UBER_TIMEOUT_MS=15000
TRANSPORT_DEFAULT_LAT=36.8065
TRANSPORT_DEFAULT_LNG=10.1815
TRANSPORT_USER_AGENT=SkillUpTn/1.0 (transport-estimate)
TRANSPORT_GEOCODE_TIMEOUT_MS=8000

# Translation Service
# Google Cloud Translation API Key
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here
# Redis URL for translation cache
REDIS_URL=redis://localhost:6379
# Translation cache TTL in seconds (default: 86400 = 24 hours)
TRANSLATION_CACHE_TTL=86400
