# MongoDB
MONGODB_URI=mongodb://localhost:27017/hr_recommendation

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Python AI Service
AI_SERVICE_URL=http://localhost:8000
AI_FEEDBACK_ENABLED=true

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=HR System <noreply@company.com>

# Anthropic (for Python service)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/users/google/callback
FRONTEND_URL=http://localhost:5173

# OpenRouter (prompt rewrite in backend /chat/rewrite)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_MS=20000
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_TITLE=SkillUpTn
# true => fail if OpenRouter is unavailable (no silent local fallback)
OPENROUTER_STRICT=true